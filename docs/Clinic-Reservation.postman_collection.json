    {
      "name": "04 - Patient Reservations (Time-Window)",
      "item": [
        {
          "name": "Booking Step 1 - Get Clinics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations/booking/clinics",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations",
                "booking",
                "clinics"
              ]
            }
          }
        },
        {
          "name": "Booking Step 2 - Get Doctors by Clinic",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations/booking/doctors?clinic_id={{clinic_id}}",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations",
                "booking",
                "doctors"
              ],
              "query": [
                {
                  "key": "clinic_id",
                  "value": "{{clinic_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Booking Step 3 - Get Schedules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations/booking/schedules?clinic_id={{clinic_id}}&doctor_id={{doctor_id}}&reservation_date={{reservation_date}}",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations",
                "booking",
                "schedules"
              ],
              "query": [
                {
                  "key": "clinic_id",
                  "value": "{{clinic_id}}"
                },
                {
                  "key": "doctor_id",
                  "value": "{{doctor_id}}"
                },
                {
                  "key": "reservation_date",
                  "value": "{{reservation_date}}"
                }
              ]
            }
          }
        },
        {
          "name": "Booking Step 4 - Get Available Windows",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations/booking/windows?doctor_clinic_schedule_id={{doctor_clinic_schedule_id}}&reservation_date={{reservation_date}}",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations",
                "booking",
                "windows"
              ],
              "query": [
                {
                  "key": "doctor_clinic_schedule_id",
                  "value": "{{doctor_clinic_schedule_id}}"
                },
                {
                  "key": "reservation_date",
                  "value": "{{reservation_date}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Reservation (Step 5)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctor_clinic_schedule_id\": {{doctor_clinic_schedule_id}},\n  \"reservation_date\": \"{{reservation_date}}\",\n  \"window_start_time\": \"{{window_start_time}}\",\n  \"complaint\": \"Flu symptoms\"\n}"
            },
            "url": {
              "raw": "{{api_base_url}}/reservations",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations"
              ]
            }
          }
        },
        {
          "name": "Get My Reservations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations"
              ]
            }
          }
        },
        {
          "name": "Get My Reservations by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base_url}}/reservations?status={{reservation_status}}",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "{{reservation_status}}"
                }
              ]
            }
          }
        },
        {
          "name": "Cancel Reservation",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cancellation_reason\": \"Recovered\"\n}"
            },
            "url": {
              "raw": "{{api_base_url}}/reservations/{{reservation_id}}/cancel",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "reservations",
                "{{reservation_id}}",
                "cancel"
              ]
            }
          }
        }
      ]
    },
