APP_NAME=CliniQueue
APP_ENV=local
APP_KEY=base64:k8SXpzqZkl+WZj8qXH3XT3EQVZ0bRCdkWZ4T8xibIp4=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
